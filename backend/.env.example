# Plantilla de credenciales de Mayrit.
# Copia este fichero como  C:\Users\<usuario>\.mayrit\.env  (carpeta privada, FUERA de OneDrive)
# y rellénalo con los valores reales. NUNCA se sube a Git.

# ── PostgreSQL (Azure) ────────────────────────────────────────────────────────
# Mismo servidor que Alea, base de datos 'mayrit' aparte.
PG_HOST=alea-db.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=mayrit
PG_USER=
PG_PASSWORD=
PG_SSLMODE=require

# ── SharePoint (puente de SOLO LECTURA durante la migración) ──────────────────
# App de Entra ID 'Alea-SharePoint' + certificado (app-only). El mismo tenant
# sirve para el sitio de Mayrit una vez concedido el permiso Sites.Selected.
SP_TENANT_ID=
SP_CLIENT_ID=
SP_SITE_URL=https://mayritbroker.sharepoint.com/sites/Mayrit-Negocio
SP_PFX_PATH=C:\Users\<usuario>\.mayrit\mayrit-sp.pfx
SP_PFX_PASSWORD=
