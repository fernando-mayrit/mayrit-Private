# Plantilla de configuración del backup. Copia a 'mayrit-backup.env' (NO se sube a Git),
# rellena los valores y protégelo:  chmod 600 mayrit-backup.env
#
PGHOST=tu-servidor.postgres.database.azure.com
PGPORT=5432
PGDATABASE=mayrit
PGUSER=mayrit_backup
PGPASSWORD=PON_AQUI_LA_PASSWORD_DEL_USUARIO_DE_SOLO_LECTURA
# Azure exige TLS; déjalo en 'require' (no lo quites):
PGSSLMODE=require
# Carpeta en el NAS donde se guardan los dumps (debe tener snapshots inmutables activadas):
BACKUP_DIR=/volume1/backups/mayrit
# Borra dumps locales con más de N días (el histórico largo lo guardan las snapshots del NAS):
RETEN_DIAS=30
# Imagen de cliente Postgres; usa una versión >= la del servidor de Azure:
PG_IMAGE=postgres:16
